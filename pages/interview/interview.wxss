/* pages/interview/interview.wxss */
page {
  background-color: #F7F8FA;
  height: 100%;
}

.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  box-sizing: border-box;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
}

.modal-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx;
  width: 100%;
  max-width: 600rpx;
  text-align: center;
  box-sizing: border-box;
}

.modal-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: rgba(22, 93, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.modal-icon-wrap.modal-icon-danger {
  background-color: rgba(245, 63, 63, 0.1);
}

.modal-icon {
  width: 56rpx;
  height: 56rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #868E96;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.modal-tip {
  font-size: 22rpx;
  color: #868E96;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  text-align: center;
}

.modal-btn-cancel {
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  color: #212529;
}

.modal-btn-confirm {
  background-color: #165DFF;
  color: #FFFFFF;
}

/* 初始选择界面 */
.init-page {
  padding: 48rpx 32rpx;
  padding-bottom: 180rpx;
}

.main-card {
  margin-bottom: 48rpx;
}

.header-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: rgba(22, 93, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.header-icon {
  width: 64rpx;
  height: 64rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: #868E96;
}

/* 选项列表 */
.option-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.option-card:active {
  background-color: #F8F9FA;
}

.option-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.option-icon-primary {
  background-color: rgba(22, 93, 255, 0.1);
}

.option-icon-orange {
  background-color: rgba(255, 125, 0, 0.1);
}

.option-icon {
  width: 40rpx;
  height: 40rpx;
}

.option-content {
  flex: 1;
  min-width: 0;
}

.option-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #212529;
  margin-bottom: 4rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #868E96;
}

.option-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
  flex-shrink: 0;
}

/* 岗位选择区域 */
.position-card {
  max-height: 800rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 24rpx;
}

.position-list {
  flex: 1;
  max-height: 480rpx;
  margin-bottom: 24rpx;
}

.position-category {
  font-size: 24rpx;
  color: #868E96;
  font-weight: 500;
  margin: 16rpx 0 8rpx;
}

.position-category:first-child {
  margin-top: 0;
}

.position-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.position-item-active {
  border-color: #165DFF;
  background-color: rgba(22, 93, 255, 0.02);
}

.position-text {
  font-size: 28rpx;
  color: #212529;
}

.position-check {
  width: 32rpx;
  height: 32rpx;
}

.start-btn {
  height: 88rpx;
  line-height: 88rpx;
  background-color: #165DFF;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.start-btn:active {
  opacity: 0.9;
}

/* JD输入区域 */
.jd-card {
  margin-top: 32rpx;
}

.jd-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #212529;
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

/* 聊天页面 */
.chat-page {
  padding-top: 100rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 150rpx;
}

/* 聊天顶部工具栏 */
.chat-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background-color: #FFFFFF;
  border-bottom: 2rpx solid #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 99;
  box-sizing: border-box;
}

.chat-header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  margin-left: -16rpx;
}

.chat-header-left:active {
  opacity: 0.7;
}

.chat-header-icon {
  width: 32rpx;
  height: 32rpx;
}

.chat-header-text {
  font-size: 28rpx;
  color: #165DFF;
}

.chat-header-center {
  flex: 1;
  text-align: center;
}

.chat-header-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #212529;
}

.chat-header-right {
  width: 80rpx;
}

.question-progress {
  text-align: right;
  font-size: 24rpx;
  color: #868E96;
  margin-bottom: 16rpx;
}

.message-container {
  height: 100%;
  min-height: 60vh;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.message-item {
  display: flex;
  flex-direction: column;
}

/* 聊天气泡 */
.chat-bubble {
  max-width: 70%;
  animation: fadeIn 0.3s ease-out;
}

.chat-bubble.ai {
  align-self: flex-start;
}

.chat-bubble.user {
  align-self: flex-end;
}

.bubble-content {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.chat-bubble.ai .bubble-content {
  background-color: #FFFFFF;
  border-radius: 16rpx 16rpx 16rpx 4rpx;
  color: #212529;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.chat-bubble.user .bubble-content {
  background-color: #165DFF;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
  color: #FFFFFF;
}

/* 打字指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
}

.typing-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #868E96;
  animation: blink 1.4s infinite both;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes blink {
  0% { opacity: 0.2; }
  20% { opacity: 1; }
  100% { opacity: 0.2; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-top: 2rpx solid #F0F0F0;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-sizing: border-box;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.switch-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #F1F3F5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.switch-icon {
  width: 32rpx;
  height: 32rpx;
}

.input-box {
  flex: 1;
  background-color: #F7F8FA;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  overflow: hidden;
}

.input-textarea {
  width: 100%;
  height: 44rpx;
  min-height: 44rpx;
  font-size: 26rpx;
  line-height: 44rpx;
  color: #212529;
  background-color: transparent;
}

.voice-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border: 2rpx solid #E9ECEF;
  border-radius: 40rpx;
  background-color: #FFFFFF;
  font-size: 26rpx;
  color: #495057;
}

.voice-btn-recording {
  background-color: #E9ECEF;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  flex-shrink: 0;
  background-color: #165DFF;
  color: #FFFFFF;
}

.send-btn-active {
  background-color: #165DFF;
  color: #FFFFFF;
}

.send-btn-disabled {
  background-color: #165DFF;
  color: #FFFFFF;
  opacity: 0.5;
}

/* 面试结束操作区 */
.finish-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-top: 2rpx solid #F0F0F0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  z-index: 100;
  box-sizing: border-box;
}

.finish-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.finish-btn-primary {
  background-color: #165DFF;
  color: #FFFFFF;
}

.finish-btn-primary:active {
  opacity: 0.9;
}

.finish-btn-secondary {
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  color: #212529;
}

.finish-btn-secondary:active {
  background-color: #F8F9FA;
}
