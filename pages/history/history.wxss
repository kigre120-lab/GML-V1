/* pages/history/history.wxss */
page {
  background-color: #F7F8FA;
}

.container {
  padding: 32rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* 操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #212529;
}

.action-btn {
  display: inline-block;
  background-color: #165DFF;
  color: #FFFFFF;
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  text-align: center;
}

/* 历史面试列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.history-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.history-card-active {
  border-left: 8rpx solid #165DFF;
}

.history-card:active {
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.history-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.history-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #212529;
  flex: 1;
  margin-right: 16rpx;
}

.history-status {
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.history-status-primary {
  background-color: rgba(22, 93, 255, 0.1);
  color: #165DFF;
}

.history-status-success {
  background-color: rgba(0, 180, 42, 0.1);
  color: #00B42A;
}

.history-status-warning {
  background-color: rgba(255, 125, 0, 0.1);
  color: #FF7D00;
}

.history-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #868E96;
}

.history-meta-icon {
  width: 28rpx;
  height: 28rpx;
}

.history-action {
  font-size: 24rpx;
  color: #165DFF;
}

.history-action:active {
  opacity: 0.8;
}

/* 问题列表 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 24rpx;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.question-card {
  display: flex;
  align-items: flex-start;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.question-card:active {
  background-color: #F8F9FA;
}

.question-content {
  flex: 1;
  margin-right: 16rpx;
  min-width: 0;
}

.question-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #212529;
  margin-bottom: 8rpx;
}

.question-desc {
  display: block;
  font-size: 24rpx;
  color: #868E96;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.question-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.question-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.question-tag-orange {
  background-color: rgba(255, 125, 0, 0.1);
  color: #FF7D00;
}

.question-tag-green {
  background-color: rgba(0, 180, 42, 0.1);
  color: #00B42A;
}

.question-tag-blue {
  background-color: rgba(22, 93, 255, 0.1);
  color: #165DFF;
}

.question-bookmark {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bookmark-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

.bookmark-active {
  opacity: 1;
}

/* 查看更多按钮 */
.view-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background-color: #FFFFFF;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #165DFF;
  margin-top: 24rpx;
}

.view-more-btn:active {
  opacity: 0.8;
}

.view-more-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
}

.modal-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx;
  width: 100%;
  max-width: 600rpx;
  text-align: center;
  box-sizing: border-box;
}

.modal-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: rgba(245, 63, 63, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.modal-icon {
  width: 56rpx;
  height: 56rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212529;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #868E96;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.text-danger {
  color: #F53F3F;
  font-weight: 500;
}

.modal-tip {
  font-size: 22rpx;
  color: #868E96;
  line-height: 1.5;
  margin-bottom: 32rpx;
  white-space: pre-line;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  text-align: center;
}

.modal-btn-cancel {
  background-color: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  color: #212529;
}

.modal-btn-confirm {
  background-color: #165DFF;
  color: #FFFFFF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  margin-bottom: 48rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: rgba(134, 142, 150, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #212529;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #868E96;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 64rpx;
  background-color: #165DFF;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.empty-btn:active {
  opacity: 0.9;
}

/* 问题区域标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-count {
  font-size: 24rpx;
  color: #868E96;
}

/* 无收藏时的示例提示 */
.question-empty {
  background-color: rgba(22, 93, 255, 0.02);
  border: 2rpx dashed #E5E7EB;
  border-radius: 16rpx;
  padding: 32rpx;
}

.question-example {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.example-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.example-icon {
  width: 32rpx;
  height: 32rpx;
}

.example-title {
  font-size: 26rpx;
  color: #868E96;
}

.example-card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.example-question {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #212529;
  margin-bottom: 12rpx;
}

.example-desc {
  display: block;
  font-size: 24rpx;
  color: #868E96;
  line-height: 1.5;
}
