<!--pages/plus/plus.wxml-->
<view class="container">
  <!-- 个人信息区域 -->
  <view class="card user-card">
    <view class="user-info">
      <view class="user-avatar">
        <image class="avatar-img" src="{{userInfo.avatarUrl || '/images/icons/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
        <text class="user-status">已授权登录</text>
      </view>
    </view>
    <view class="times-badge">
      <text class="times-label">当前剩余次数</text>
      <text class="times-value">{{remainingTimes}}</text>
      <text class="times-unit">通用次数</text>
    </view>
  </view>

  <!-- 通用次数付费区 -->
  <view class="card">
    <text class="section-title">通用次数包</text>
    <text class="section-desc">通用于模拟面试/简历优化/JD分析，永久有效</text>
    
    <view class="package-grid">
      <!-- 单次套餐 -->
      <view class="package-card" bindtap="selectPackage" data-id="1">
        <text class="package-name">单次</text>
        <text class="package-price">¥4.9</text>
        <view class="package-btn">购买</view>
      </view>

      <!-- 5次套餐 -->
      <view class="package-card package-card-active" bindtap="selectPackage" data-id="5">
        <view class="package-tag">人均首选</view>
        <text class="package-name">5次</text>
        <text class="package-price">¥19.9</text>
        <text class="package-original">¥49.5</text>
        <view class="package-btn package-btn-primary">购买</view>
      </view>

      <!-- 10次套餐 -->
      <view class="package-card" bindtap="selectPackage" data-id="10">
        <view class="package-tag package-tag-orange">最划算</view>
        <text class="package-name">10次</text>
        <text class="package-price">¥29.9</text>
        <text class="package-original">¥99</text>
        <view class="package-btn package-btn-primary">购买</view>
      </view>
    </view>
  </view>

  <!-- 高端增值服务区 -->
  <view class="premium-card">
    <view class="premium-icon-wrap">
      <image class="premium-icon" src="/images/icons/user-tie.png" mode="aspectFit"></image>
    </view>
    <view class="premium-content">
      <view class="premium-header">
        <text class="premium-title">大厂在职面试官1V1模拟面试</text>
        <view class="premium-price-wrap">
          <text class="premium-price">¥199</text>
          <text class="premium-original">¥299</text>
        </view>
      </view>
      <text class="premium-desc">阿里/字节/腾讯等大厂在职面试官1小时1对1实战模拟，出具专业评估报告+针对性求职建议</text>
      <view class="premium-btn" bindtap="bookInterview">立即预约</view>
    </view>
  </view>

  <!-- 邀请福利区 -->
  <view class="invite-card">
    <view class="invite-icon-wrap">
      <image class="invite-icon" src="/images/icons/gift.png" mode="aspectFit"></image>
    </view>
    <view class="invite-content">
      <text class="invite-title">邀请好友得免费次数</text>
      <text class="invite-desc">邀请1位好友完成首次面试，双方各得1次免费通用次数</text>
    </view>
    <view class="invite-btn" bindtap="inviteFriend">立即邀请</view>
  </view>

  <!-- 求职交流群 -->
  <view class="card group-card">
    <view class="group-icon-wrap">
      <image class="group-icon" src="/images/icons/users.png" mode="aspectFit"></image>
    </view>
    <view class="group-content">
      <text class="group-title">加入求职交流群</text>
      <text class="group-desc">交流面试经验、内推信息、大厂面经</text>
    </view>
    <view class="group-btn" bindtap="showQrcodeModal">点击进群</view>
  </view>

  <!-- 二维码弹窗 -->
  <view class="modal-mask" wx:if="{{showQrcodeModal}}" catchtouchmove="preventTouchMove" bindtap="hideQrcodeModal">
    <view class="modal-card" catchtap="preventTouchMove">
      <text class="modal-title">求职交流群</text>
      <text class="modal-desc">扫描下方二维码加入群聊，和小伙伴一起交流求职经验</text>
      <image class="qrcode-img" src="/images/icons/group-qrcode.png" mode="aspectFit"></image>
      <view class="modal-close-btn" bindtap="hideQrcodeModal">关闭</view>
    </view>
  </view>
</view>
