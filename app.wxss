/* app.wxss - 全局样式 */
/* 颜色变量 */
page {
  --primary: #165DFF;
  --secondary: #F7F8FA;
  --neutral: #868E96;
  --dark: #212529;
  --light: #F1F3F5;
  --success: #00B42A;
  --warning: #FF7D00;
  --danger: #F53F3F;
  
  /* 字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: var(--dark);
  background-color: var(--secondary);
  -webkit-font-smoothing: antialiased;
}

/* 通用容器 */
.container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--secondary);
  padding-bottom: 180rpx;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 主按钮 */
.btn-primary {
  background-color: var(--primary);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.btn-primary:active {
  opacity: 0.9;
}

/* 次级按钮 */
.btn-secondary {
  background-color: #FFFFFF;
  color: var(--dark);
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

/* 文字颜色 */
.text-primary { color: var(--primary); }
.text-neutral { color: var(--neutral); }
.text-dark { color: var(--dark); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }

/* 背景色 */
.bg-primary { background-color: var(--primary); }
.bg-secondary { background-color: var(--secondary); }
.bg-white { background-color: #FFFFFF; }
.bg-light { background-color: var(--light); }

/* 弹性布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-8 { gap: 16rpx; }
.gap-16 { gap: 32rpx; }

/* 间距 */
.p-4 { padding: 32rpx; }
.p-5 { padding: 40rpx; }
.p-6 { padding: 48rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-4 { margin-top: 32rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-4 { margin-bottom: 32rpx; }

/* 圆角 */
.rounded { border-radius: 12rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded-full { border-radius: 9999rpx; }

/* 阴影 */
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04); }
.shadow { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08); }

/* 动画 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 滚动条隐藏 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
